<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PhotoEditor.Desktop.ViewModels"
        xmlns:controls="using:PhotoEditor.Desktop.Controls"
        x:Class="PhotoEditor.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="True"
        Title="PhotoEditor" Width="1200" Height="800"
        WindowStartupLocation="CenterScreen">

    <Grid ColumnDefinitions="*, 350">
        <!-- Canvas Area -->
        <Border Grid.Column="0" Background="#1e1e1e" ClipToBounds="True">
            <controls:SkiaViewportMain 
                OriginalImage="{Binding OriginalImage}"
                Parameters="{Binding Parameters}" />
        </Border>
        
        <!-- Controls Area -->
        <ScrollViewer Grid.Column="1" Background="#252525">
            <StackPanel Spacing="15" Margin="20">
                <Button Content="Load Image" Click="OnLoadImageClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                <Button Content="Export" Click="OnExportClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>

                <TextBlock Text="Basic Adjustments" FontWeight="Bold" Margin="0,10,0,0"/>
                
                <TextBlock Text="Exposure" />
                <Slider Minimum="-5" Maximum="5" TickFrequency="0.1" IsSnapToTickEnabled="True" Value="{Binding Exposure}" />

                <TextBlock Text="Contrast" />
                <Slider Minimum="0" Maximum="2" TickFrequency="0.05" IsSnapToTickEnabled="True" Value="{Binding Contrast}" />

                <TextBlock Text="Saturation" />
                <Slider Minimum="0" Maximum="2" TickFrequency="0.05" IsSnapToTickEnabled="True" Value="{Binding Saturation}" />
                
                <TextBlock Text="Preset System" FontWeight="Bold" Margin="0,10,0,0"/>
                <Button Content="Save Preset" Click="OnSavePresetClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                <Button Content="Load Preset" Click="OnLoadPresetClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
